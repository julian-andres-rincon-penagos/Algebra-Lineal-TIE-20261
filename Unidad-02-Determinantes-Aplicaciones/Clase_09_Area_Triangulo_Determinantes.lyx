\begin_layout Seccion
Rotación del Triángulo
\end_layout

\begin_layout Standard
Del ejercicio anterior tenemos los puntos 
\begin_inset Formula $A\left(\frac{\sqrt{3}}{2},\frac{1}{2}\right)$
\end_inset


\series bold
 ,

\series default
 
\begin_inset Formula $B\left(-\frac{\sqrt{3}}{2},\frac{1}{2}\right)$
\end_inset

 y 
\begin_inset Formula $C\left(0,-1\right)$
\end_inset

,
 al ubicarlos en una matriz homogénea y multiplicarnos por una matriz de rotación tenemos 
\begin_inset Formula 
\[
\begin{bmatrix}\frac{\sqrt{3}}{2} & -\frac{\sqrt{3}}{3} & 0\\
\frac{1}{2} & \frac{1}{2} & -1\\
1 & 1 & 1
\end{bmatrix}\cdot\begin{bmatrix}\cos\theta & -\sin\theta & 0\\
\sin\theta & \cos\theta & 0\\
0 & 0 & 1
\end{bmatrix}
\]

\end_inset

 Si consideremos 
\begin_inset Formula $\theta=15°$
\end_inset

 entonces 
\begin_inset Formula 
\[
R=\begin{bmatrix}\frac{\sqrt{6}}{4}+\frac{\sqrt{2}}{4} & -\frac{\sqrt{6}}{4}+\frac{\sqrt{2}}{4} & 0\\
\frac{\sqrt{6}}{4}-\frac{\sqrt{2}}{4} & \frac{\sqrt{6}}{4}+\frac{\sqrt{2}}{4} & 0\\
0 & 0 & 1
\end{bmatrix}
\]

\end_inset

 Así 
\begin_inset Formula 
\[
\begin{bmatrix}\frac{\sqrt{3}}{2} & -\frac{\sqrt{3}}{3} & 0\\
\frac{1}{2} & \frac{1}{2} & -1\\
1 & 1 & 1
\end{bmatrix}\cdot\begin{bmatrix}\frac{\sqrt{6}}{4}+\frac{\sqrt{2}}{4} & -\frac{\sqrt{6}}{4}+\frac{\sqrt{2}}{4} & 0\\
\frac{\sqrt{6}}{4}+\frac{\sqrt{2}}{4} & \frac{\sqrt{6}}{4}+\frac{\sqrt{2}}{4} & 0\\
0 & 0 & 1
\end{bmatrix}=\begin{bmatrix}\frac{\sqrt{2}}{2} & -\frac{\sqrt{6}}{4}-\frac{\sqrt{2}}{4} & \frac{\sqrt{6}}{4}-\frac{\sqrt{2}}{4}\\
\frac{\sqrt{2}}{2} & \frac{\sqrt{6}}{4}-\frac{\sqrt{2}}{4} & -\frac{\sqrt{6}}{4}-\frac{\sqrt{2}}{4}\\
1 & 1 & 1
\end{bmatrix}
\]

\end_inset

 Con esto obtenemos los puntos 
\begin_inset Formula $A\left(\frac{\sqrt{2}}{2},\frac{\sqrt{2}}{2}\right)$
\end_inset

,
 
\begin_inset Formula $B\left(-\frac{\sqrt{6}}{4}-\frac{\sqrt{2}}{4},\frac{\sqrt{6}}{4}-\frac{\sqrt{2}}{4}\right)$
\end_inset

 y 
\begin_inset Formula $C\left(\frac{\sqrt{6}}{4}-\frac{\sqrt{2}}{4},-\frac{\sqrt{6}}{4}-\frac{\sqrt{2}}{4}\right)$
\end_inset

 .
 Al graficar podemos comprobar que es el mismo triángulo pero esta rotado 
\begin_inset Formula $15°$
\end_inset

.
