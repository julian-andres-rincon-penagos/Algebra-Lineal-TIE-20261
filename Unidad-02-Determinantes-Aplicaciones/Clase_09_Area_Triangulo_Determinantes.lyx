\begin_inset Caption Standard

\begin_layout Plain Layout
Gráfica de la Circunferencia 
\begin_inset Formula $x^{2}+y^{2}=1$
\end_inset

 y cortes con la recta 
\begin_inset Formula $y=\frac{\sqrt{3}}{3}x$
\end_inset


\end_layout

\end_inset


\end_layout

\begin_layout Plain Layout

\end_layout

\end_inset

 Al reemplazar la 
\begin_inset Formula $y$
\end_inset

 en la ecuación de la circunferencia tenemos 
\begin_inset Formula 
\begin{align*}
x^{2}+\left(\frac{\sqrt{3}}{3}x\right)^{2} & =1\\
x^{2}+\frac{1}{3}x^{2} & =1\\
\frac{4}{3}x^{2} & =1\\
x^{2} & =\frac{3}{4}\\
x & =\pm\frac{\sqrt{3}}{2}
\end{align*}

\end_inset

 Con esto sabemos que el punto de corte de la circunferencia con la recta ocurre en 
\begin_inset Formula $x=\frac{\sqrt{3}}{2}$
\end_inset

,
 por ahora solo nos interesa el valor positivo,
 para encontrar 
\begin_inset Formula $y$
\end_inset

 hacemos 
\begin_inset Formula 
\begin{align*}
y & =\frac{\sqrt{3}}{3}\left(\frac{\sqrt{3}}{2}\right)\\
 & =\frac{3}{6}=\frac{1}{2}
\end{align*}

\end_inset

 Esto quiere decir que tenemos el punto de corte 
\begin_inset Formula $A\left(\frac{\sqrt{3}}{2},\frac{1}{2}\right)$
\end_inset

.
\begin_inset Newline newline
\end_inset


\end_layout

\begin_layout Standard
Ahora al ángulo inicial 
\begin_inset Formula $\alpha$
\end_inset

 le sumamos 
\begin_inset Formula $120°$
\end_inset

 entonces tenemos una nueva recta 
\begin_inset Formula 
\begin{align*}
y & =\tan\left(150°\right)\\
 & =-\frac{\sqrt{3}}{3}
\end{align*}

\end_inset

 al aplicar el mismo procedimiento sobre la circunferencia obtenemos el punto de corte 
\begin_inset Formula $B\left(-\frac{\sqrt{3}}{3},\frac{1}{2}\right)$
\end_inset

 dado que al hacer 
\begin_inset Formula $\left(-\frac{\sqrt{3}}{3}x\right)^{2}$
\end_inset

 queda positivo.
\begin_inset Newline newline
\end_inset


\end_layout

\begin_layout Standard
Para el tercer punto,
 al ángulo inicial 
\begin_inset Formula $\alpha$
\end_inset

 sumamos otros 
\begin_inset Formula $120°$
\end_inset

 lo cual nos da 
\begin_inset Formula $270°$
\end_inset

 que nos da exactamente el punto 
\begin_inset Formula $C\left(0,-1\right)$
\end_inset

.
\begin_inset Newline newline
\end_inset


\end_layout

