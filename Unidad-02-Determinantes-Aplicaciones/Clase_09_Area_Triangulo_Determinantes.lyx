\begin_layout Standard
Dado un triángulo de coordenadas 
\begin_inset Formula $A\left(x_{1},y_{1}\right)$
\end_inset

,
 
\begin_inset Formula $B\left(x_{2},y_{2}\right)$
\end_inset

 y 
\begin_inset Formula $C\left(x_{3},y_{3}\right)$
\end_inset

 el área del triángulo se calcula así 
\begin_inset Formula 
\[
A=\frac{\left|\det\left(P\right)\right|}{2}
\]

\end_inset

 donde 
\begin_inset Formula 
\[
P=\begin{bmatrix}x_{1} & y_{1} & 1\\
x_{2} & y_{2} & 1\\
x_{3} & y_{3} & 1
\end{bmatrix}
\]

\end_inset

 
\end_layout

