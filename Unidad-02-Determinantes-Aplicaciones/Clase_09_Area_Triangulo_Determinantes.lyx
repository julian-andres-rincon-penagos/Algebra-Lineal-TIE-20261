\begin_layout Standard
Para calcular el área hacemos:
\begin_inset Formula 
\[
P=\begin{bmatrix}2 & 3 & 1\\
5 & 13 & 1\\
11 & 7 & 1
\end{bmatrix}
\]

\end_inset

 Entonces el área esta dada por 
\begin_inset Formula 
\[
A=\frac{\left|\det\left(P\right)\right|}{2}
\]

\end_inset

 Para calcular el determinante vamos a usar la expansión de Laplace 
\begin_inset Formula 
\begin{align*}
\det\left(P\right) & =2\begin{bmatrix}13 & 1\\
7 & 1
\end{bmatrix}-3\begin{bmatrix}5 & 1\\
11 & 1
\end{bmatrix}+1\begin{bmatrix}5 & 13\\
11 & 7
\end{bmatrix}\\
 & =2\left(13-7\right)-3\left(5-11\right)+1\left(35-143\right)\\
 & =2\left(6\right)-3\left(-6\right)+1\left(-108\right)\\
 & =12+18-108\\
 & =-78
\end{align*}

\end_inset

 Así 
\begin_inset Formula 
\begin{align*}
A & =\frac{\left|\det\left(P\right)\right|}{2}\\
 & =\frac{\left|-78\right|}{2}\\
 & =39\text{ u}^{2}
\end{align*}

\end_inset


\end_layout

