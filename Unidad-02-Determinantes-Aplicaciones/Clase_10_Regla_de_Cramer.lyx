\begin_layout Seccion
Ecuación Canónica de la Circunferencia
\end_layout

\begin_layout Standard
Tenemos la siguiente ecuación,
 que corresponde a la ecuación canónica de la circunferencia 
\begin_inset Formula 
\[
\left(x-h\right)^{2}+\left(y-k\right)^{2}=r^{2}
\]

\end_inset

 Desarrollando cuadrados tenemos 
\begin_inset Formula 
\begin{align*}
x^{2}-2hx+h^{2}+y^{2}-2ky+k^{2} & =r^{2}\\
x^{2}+y^{2}-2hx-2ky+h^{2}+k^{2}-r^{2} & =0
\end{align*}

\end_inset

 Al comparar esta ecuación con la ecuación general de la circunferencia tenemos que si 
\begin_inset Formula $C=-2h$
\end_inset

 entonces 
\begin_inset Formula $h=-\frac{C}{2}$
\end_inset

,
 
\begin_inset Formula $D=-2k$
\end_inset

,
 entonces 
\begin_inset Formula $k=-\frac{D}{2}$
\end_inset

 y 
\begin_inset Formula $E=h^{2}+k^{2}-r^{2}$
\end_inset

 entonces 
\begin_inset Formula 
\[
r^{2}=h^{2}+k^{2}-E
\]

\end_inset

 Sabiendo que 
\begin_inset Formula $h=-\frac{C}{2}$
\end_inset

 y 
\begin_inset Formula $k=-\frac{D}{2}$
\end_inset

 entonces 
\begin_inset Formula 
\begin{align*}
r^{2} & =\left(-\frac{C}{2}\right)^{2}+\left(-\frac{D}{2}\right)^{2}-E\\
r^{2} & =\frac{C^{2}}{4}+\frac{D^{2}}{4}-\frac{4E}{4}\\
r & =\sqrt{\frac{1}{4}\left(C^{2}+D^{2}-4E\right)}\\
r & =\frac{1}{2}\sqrt{C^{2}+D^{2}-4E}
\end{align*}

\end_inset


\end_layout

